  "frame": {
    "name": "fRevoke",
    "homeUrl": "https://frevoke.vercel.app",
    "iconUrl": "https://frevoke.vercel.app/logo.png",
    "splashImageUrl": "https://frevoke.vercel.app/logo.png",
